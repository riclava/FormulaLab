generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum FormulaRelationType {
  prerequisite
  related
  confusable
  application_of
}

enum ReviewItemType {
  recall
  recognition
  application
}

enum ReviewResult {
  easy
  good
  hard
  again
}

enum StudySessionStatus {
  active
  completed
  abandoned
}

enum ProductEventType {
  weak_formula_impression
  weak_formula_opened
}

model User {
  id                 String   @id @default(cuid())
  email              String?  @unique
  displayName        String?
  anonymousSessionId String?  @unique
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  formulaStates      UserFormulaState[]
  reviewLogs         ReviewLog[]
  memoryHooks        FormulaMemoryHook[]
  diagnosticAttempts DiagnosticAttempt[]
  studySessions      StudySession[]
  productEvents      ProductEvent[]
  ownedFormulas      Formula[]            @relation("FormulaOwner")
  authIdentity       AuthUser?

  @@map("users")
}

model AuthUser {
  id            String   @id @default(cuid())
  email         String   @unique
  emailVerified Boolean  @default(false)
  name          String
  image         String?
  learnerId     String?  @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  learner  User?         @relation(fields: [learnerId], references: [id], onDelete: SetNull)
  sessions AuthSession[]
  accounts AuthAccount[]

  @@map("auth_users")
}

model AuthSession {
  id        String   @id @default(cuid())
  userId    String
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user AuthUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("auth_sessions")
}

model AuthAccount {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user AuthUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("auth_accounts")
}

model AuthVerification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@index([expiresAt])
  @@map("auth_verifications")
}

model Formula {
  id               String   @id @default(cuid())
  ownerUserId      String?
  slug             String   @unique
  title            String
  expressionLatex  String
  domain           String
  subdomain        String?
  oneLineUse       String
  meaning          String
  intuition        String?
  derivation       String?
  useConditions    String[]
  nonUseConditions String[]
  antiPatterns     String[]
  typicalProblems  String[]
  examples         String[]
  plotConfig       Json?
  difficulty       Int
  tags             String[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  variables         FormulaVariable[]
  reviewItems       ReviewItem[]
  outgoingRelations FormulaRelation[]   @relation("FormulaRelationFrom")
  incomingRelations FormulaRelation[]   @relation("FormulaRelationTo")
  userStates        UserFormulaState[]
  reviewLogs        ReviewLog[]
  memoryHooks       FormulaMemoryHook[]
  productEvents     ProductEvent[]
  owner             User?               @relation("FormulaOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)

  @@index([domain, subdomain])
  @@index([ownerUserId])
  @@map("formulas")
}

model FormulaVariable {
  id          String   @id @default(cuid())
  formulaId   String
  symbol      String
  name        String
  description String
  unit        String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  formula Formula @relation(fields: [formulaId], references: [id], onDelete: Cascade)

  @@index([formulaId])
  @@map("formula_variables")
}

model FormulaRelation {
  id            String              @id @default(cuid())
  fromFormulaId String
  toFormulaId   String
  relationType  FormulaRelationType
  note          String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  fromFormula Formula @relation("FormulaRelationFrom", fields: [fromFormulaId], references: [id], onDelete: Cascade)
  toFormula   Formula @relation("FormulaRelationTo", fields: [toFormulaId], references: [id], onDelete: Cascade)

  @@unique([fromFormulaId, toFormulaId, relationType])
  @@index([toFormulaId])
  @@map("formula_relations")
}

model ReviewItem {
  id          String         @id @default(cuid())
  formulaId   String
  type        ReviewItemType
  prompt      String
  answer      String
  explanation String?
  difficulty  Int
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  formula    Formula     @relation(fields: [formulaId], references: [id], onDelete: Cascade)
  reviewLogs ReviewLog[]

  @@index([formulaId, type])
  @@map("review_items")
}

model UserFormulaState {
  id                 String    @id @default(cuid())
  userId             String
  formulaId          String
  memoryStrength     Float     @default(0)
  stability          Float     @default(0)
  difficultyEstimate Float     @default(0)
  lastReviewedAt     DateTime?
  nextReviewAt       DateTime?
  totalReviews       Int       @default(0)
  correctReviews     Int       @default(0)
  lapseCount         Int       @default(0)
  consecutiveCorrect Int       @default(0)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  formula Formula @relation(fields: [formulaId], references: [id], onDelete: Cascade)

  @@unique([userId, formulaId])
  @@index([formulaId])
  @@map("user_formula_states")
}

model ReviewLog {
  id               String       @id @default(cuid())
  userId           String
  formulaId        String
  reviewItemId     String
  studySessionId   String?
  result           ReviewResult
  responseTimeMs   Int?
  confidence       Int?
  memoryHookUsedId String?
  reviewedAt       DateTime     @default(now())

  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  formula        Formula            @relation(fields: [formulaId], references: [id], onDelete: Cascade)
  reviewItem     ReviewItem         @relation(fields: [reviewItemId], references: [id], onDelete: Cascade)
  studySession   StudySession?      @relation(fields: [studySessionId], references: [id], onDelete: SetNull)
  memoryHookUsed FormulaMemoryHook? @relation(fields: [memoryHookUsedId], references: [id], onDelete: SetNull)

  @@index([userId, reviewedAt])
  @@index([formulaId])
  @@map("review_logs")
}

model DiagnosticAttempt {
  id             String   @id @default(cuid())
  userId         String
  domain         String
  reviewItemIds  String[]
  weakFormulaIds String[]
  completedAt    DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, completedAt])
  @@map("diagnostic_attempts")
}

model FormulaMemoryHook {
  id        String   @id @default(cuid())
  userId    String
  formulaId String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  formula    Formula     @relation(fields: [formulaId], references: [id], onDelete: Cascade)
  reviewLogs ReviewLog[]

  @@unique([userId, formulaId])
  @@index([formulaId])
  @@map("formula_memory_hooks")
}

model StudySession {
  id          String             @id @default(cuid())
  userId      String
  domain      String
  status      StudySessionStatus @default(active)
  startedAt   DateTime           @default(now())
  completedAt DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewLogs    ReviewLog[]
  productEvents ProductEvent[]

  @@index([userId, startedAt])
  @@map("study_sessions")
}

model ProductEvent {
  id             String           @id @default(cuid())
  userId         String
  formulaId      String?
  studySessionId String?
  type           ProductEventType
  createdAt      DateTime         @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  formula      Formula?      @relation(fields: [formulaId], references: [id], onDelete: SetNull)
  studySession StudySession? @relation(fields: [studySessionId], references: [id], onDelete: SetNull)

  @@index([userId, type, createdAt])
  @@index([formulaId, type])
  @@map("product_events")
}
