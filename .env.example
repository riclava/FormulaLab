# PostgreSQL connection used by Prisma and the app server.
# The default matches docker-compose.yml.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/formulalab?schema=public"

# Public site URL used by client-side auth helpers and redirects.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Secret used by Better Auth to sign auth data.
# Generate a real local value with: openssl rand -base64 32
BETTER_AUTH_SECRET="replace-with-a-random-32-byte-secret"

# Server-side canonical auth URL. Usually the same as NEXT_PUBLIC_APP_URL.
BETTER_AUTH_URL="http://localhost:3000"

# Optional comma-separated admin emails for internal maintenance routes.
ADMIN_EMAILS=""

# Optional base URL for Playwright/e2e tests.
# Leave empty to skip e2e tests that require a running app.
E2E_BASE_URL=""

# OpenAI-compatible LLM settings used by formula draft and plot config generation.
# Supported providers: kimi, deepseek, custom.
LLM_PROVIDER="kimi"
LLM_API_KEY=""

# Optional overrides. Leave empty to use the provider preset below.
LLM_API_BASE_URL=""
LLM_MODEL=""

# Request timeout in milliseconds. The app clamps this between 1000 and 120000.
LLM_API_TIMEOUT_MS="120000"

# Provider presets when LLM_API_BASE_URL or LLM_MODEL are empty:
# kimi -> https://api.moonshot.cn/v1, kimi-k2.6
# deepseek -> https://api.deepseek.com/v1, deepseek-chat
